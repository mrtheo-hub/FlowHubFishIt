-- Fishing Hook
LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and not item.Name:lower():find("rod") then
        task.wait(0.5)
        local rarity = item:GetAttribute("Rarity") or "Common"
        
        if getgenv().FlowConfig.WebhookFilters[rarity] then
            local imageId = item.TextureId:match("%d+") or "0"
            local thumbUrl = "https://www.roblox.com/asset-thumbnail/image?assetId=" .. imageId .. "&width=420&height=420&format=png"
            
            SendWebhook({
                ["embeds"] = {{
                    ["title"] = "🎣 New Catch: " .. item.Name,
                    ["color"] = (rarity == "Legendary" and 0xFFD700 or 0x00B4D8),
                    ["thumbnail"] = {["url"] = thumbUrl},
                    ["fields"] = {
                        {["name"] = "Rarity", ["value"] = "```" .. rarity .. "```", ["inline"] = true},
                        {["name"] = "Player", ["value"] = "```" .. LocalPlayer.Name .. "```", ["inline"] = true}
                    },
                    ["footer"] = {["text"] = "Flow Hub v1.0.0 Alpha | " .. os.date("%X")}
                }}
            })
        end
    end
end)

