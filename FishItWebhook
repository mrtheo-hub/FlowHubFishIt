local function monitorPlayer(p)
    local function checkItem(item)
        if not item:IsA("Tool") or item:GetAttribute("FlowLogged") then return end
        task.wait(1)
        
        -- Deteksi Rarity (Atribut atau Value)
        local rar = item:GetAttribute("Rarity") or (item:FindFirstChild("Rarity") and item.Rarity.Value) or "Common"
        local rarStr = tostring(rar):sub(1,1):upper() .. tostring(rar):sub(2):lower()
        
        if getgenv().FlowConfig.Filters[rarStr] then
            item:SetAttribute("FlowLogged", true)
            local mut = item:GetAttribute("Mutation") or (item:FindFirstChild("Mutation") and item.Mutation.Value) or "None"
            local weight = item:GetAttribute("Weight") or (item:FindFirstChild("Weight") and item.Weight.Value) or 0
            
            local ping = nil
            if (item.Name == "Ruby" and tostring(mut) == "Gemstone") or rarStr == "Forgotten" then ping = "@here" end

            sendWebhook({
                ["content"] = ping,
                ["embeds"] = {{
                    ["title"] = "🎣 Catch: " .. item.Name,
                    ["fields"] = {
                        {["name"] = "Player", ["value"] = p.Name, ["inline"] = true},
                        {["name"] = "Rarity", ["value"] = rarStr, ["inline"] = true},
                        {["name"] = "Weight", ["value"] = string.format("%.2f", weight) .. " kg", ["inline"] = true},
                        {["name"] = "Mutation", ["value"] = tostring(mut), ["inline"] = true},
                        {["name"] = "JobID", ["value"] = game.JobId, ["inline"] = false}
                    },
                    ["color"] = 0x00B4D8
                }}
            })
        end
    end

    p.CharacterAdded:Connect(function(c) c.ChildAdded:Connect(checkItem) end)
    if p.Character then p.Character.ChildAdded:Connect(checkItem) end
    p.ChildAdded:Connect(function(b) if b:IsA("Backpack") then b.ChildAdded:Connect(checkItem) end end)
    if p:FindFirstChild("Backpack") then p.Backpack.ChildAdded:Connect(checkItem) end
end

for _, p in pairs(Players:GetPlayers()) do monitorPlayer(p) end
Players.PlayerAdded:Connect(monitorPlayer)
