-- [ WEBHOOK LOGIC & HELPERS ]
local function getActiveFilters()
    local active = {}
    for k, v in pairs(getgenv().FlowConfig.Filters) do if v then table.insert(active, k) end end
    return #active > 0 and table.concat(active, ", ") or "None"
end

local function getServerStats()
    local list = ""
    for _, p in pairs(Players:GetPlayers()) do
        local stats = p:FindFirstChild("leaderstats")
        local caught = stats and stats:FindFirstChild("Caught") and stats.Caught.Value or 0
        local rarest = stats and stats:FindFirstChild("Rarest") and stats.Rarest.Value or "None"
        list = list .. "👤 **" .. p.Name .. "**\n> Rarest: `" .. rarest .. "` | Total: `" .. caught .. "`\n"
    end
    return list == "" and "No active players." or list
end

local function getPlayerLocation(p)
    if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then return "Unknown Zone" end
    local rootPos = p.Character.HumanoidRootPart.Position
    local closest, minDist = "Unknown Zone", math.huge
    for name, pos in pairs(Islands) do
        local dist = (rootPos - pos).Magnitude
        if dist < minDist then minDist = dist; closest = name end
    end
    return (minDist < 600) and closest or "Unknown Zone"
end

local function sendWebhook(data)
    if getgenv().FlowConfig.WebhookURL == "" or not requestFunc then return end
    task.spawn(function()
        pcall(function()
            requestFunc({
                Url = getgenv().FlowConfig.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end)
end

