-- [[ FUNCTIONS ]]
local function SendWebhook(data)
    if getgenv().FlowConfig.WebhookURL ~= "" then
        pcall(function()
            request({
                Url = getgenv().FlowConfig.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end
end

