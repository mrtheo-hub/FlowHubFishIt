-- [[ CATCH MONITORING ENGINE (V2) ]]
local function monitorPlayer(p)
    local function processCatch(item)
        if not item:IsA("Tool") or item:GetAttribute("FlowProcessed") then return end
        
        -- Brute Force Data Detection
        task.wait(1.5)
        local rarity = item:GetAttribute("Rarity") or (item:FindFirstChild("Rarity") and item.Rarity.Value) or (item:FindFirstChild("Data") and item.Data:FindFirstChild("Rarity") and item.Data.Rarity.Value) or "Common"
        local mutation = item:GetAttribute("Mutation") or (item:FindFirstChild("Mutation") and item.Mutation.Value) or "None"
        local weight = item:GetAttribute("Weight") or (item:FindFirstChild("Weight") and item.Weight.Value) or 0
        
        local rarStr = tostring(rarity):sub(1,1):upper() .. tostring(rarity):sub(2):lower()
        
        if getgenv().FlowConfig.Filters[rarStr] then
            item:SetAttribute("FlowProcessed", true)
            local ping = nil
            if (item.Name == "Ruby" and tostring(mutation) == "Gemstone") or rarStr == "Forgotten" then ping = "@here" end

            sendWebhook({
                ["content"] = ping,
                ["embeds"] = {{
                    ["title"] = "🎣 CATCH LOGGED: " .. item.Name,
                    ["color"] = 0x00B4D8,
                    ["fields"] = {
                        {["name"] = "Player", ["value"] = p.Name, ["inline"] = true},
                        {["name"] = "Rarity", ["value"] = rarStr, ["inline"] = true},
                        {["name"] = "Mutation", ["value"] = tostring(mutation), ["inline"] = true},
                        {["name"] = "Weight", ["value"] = string.format("%.2f", weight) .. "kg", ["inline"] = true},
                        {["name"] = "JobID", ["value"] = game.JobId, ["inline"] = false}
                    }
                }}
            })
        end
    end

    p.CharacterAdded:Connect(function(c) c.ChildAdded:Connect(processCatch) end)
    p.ChildAdded:Connect(function(b) if b:IsA("Backpack") then b.ChildAdded:Connect(processCatch) end end)
    if p:FindFirstChild("Backpack") then p.Backpack.ChildAdded:Connect(processCatch) end
end

for _, p in pairs(Players:GetPlayers()) do monitorPlayer(p) end
Players.PlayerAdded:Connect(monitorPlayer)

