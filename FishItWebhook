-- [ WEBHOOK ENGINE ]
local function sendWebhook(data)
    if getgenv().FlowConfig.WebhookURL == "" or not requestFunc then return end
    task.spawn(function()
        pcall(function()
            requestFunc({
                Url = getgenv().FlowConfig.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end)
end

-- [ UPDATE DETECTOR ENGINE ]
local function checkGameUpdate()
    task.spawn(function()
        while task.wait(300) do -- Cek tiap 5 menit
            local pInfo = Market:GetProductInfo(game.PlaceId)
            if pInfo.Updated ~= getgenv().FlowConfig.LastUpdateDate then
                getgenv().FlowConfig.LastUpdateDate = pInfo.Updated
                sendWebhook({
                    ["content"] = "@everyone | <@" .. getgenv().FlowConfig.MyDiscordID .. ">",
                    ["embeds"] = {{
                        ["title"] = "🚨 FISH IT UPDATE DETECTED!",
                        ["description"] = "Game has been updated or restarted!\n**Time:** `" .. pInfo.Updated .. "`\n**Action:** Check code shifts immediately.",
                        ["color"] = 0xFF0000
                    }}
                })
            end
        end
    end)
end
