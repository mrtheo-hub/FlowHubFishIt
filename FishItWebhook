-- [ WEBHOOK HELPERS ]
local function sendWebhook(data)
    if getgenv().FlowConfig.WebhookURL == "" or not requestFunc then return end
    task.spawn(function()
        pcall(function()
            requestFunc({
                Url = getgenv().FlowConfig.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end)
end

local function getServerStats()
    local list = ""
    for _, p in pairs(Players:GetPlayers()) do
        local stats = p:FindFirstChild("leaderstats")
        local caught = stats and stats:FindFirstChild("Caught") and stats.Caught.Value or 0
        local rarest = stats and stats:FindFirstChild("Rarest") and stats.Rarest.Value or "None"
        list = list .. "👤 **" .. p.Name .. "** | Rarest: `" .. rarest .. "` | Total: `" .. caught .. "`\n"
    end
    return list
end

-- [ FPS BOOSTER PERMANENT ]
local function cleanPart(v)
    if v:IsA("BasePart") then
        v.Material = Enum.Material.SmoothPlastic
        v.CastShadow = false
        v.Reflectance = 0
    elseif v:IsA("Texture") or v:IsA("Decal") or v:IsA("ParticleEmitter") or v:IsA("Atmosphere") or v:IsA("Sky") or v:IsA("Trail") then
        v:Destroy()
    end
end

workspace.DescendantAdded:Connect(function(v)
    if getgenv().FlowConfig.FPSBooster then cleanPart(v) end
end)

