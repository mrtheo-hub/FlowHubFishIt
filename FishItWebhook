local function getActiveRarities()
    local active = {}
    for k, v in pairs(FlowConfig.Filters) do if v then table.insert(active, k) end end
    return #active > 0 and table.concat(active, ", ") or "None"
end

local function getServerPlayersData()
    local pData = ""
    for _, p in pairs(Players:GetPlayers()) do
        local total = (p:FindFirstChild("leaderstats") and p.leaderstats:FindFirstChild("Caught")) and p.leaderstats.Caught.Value or "Unknown"
        local rarest = (p:FindFirstChild("leaderstats") and p.leaderstats:FindFirstChild("Rarest")) and p.leaderstats.Rarest.Value or "Unknown"
        pData = pData .. "👤 **" .. p.Name .. "**\n> Total: `" .. total .. "` | Rarest: `" .. rarest .. "`\n"
    end
    if pData == "" then pData = "No players found." end
    return pData
end

