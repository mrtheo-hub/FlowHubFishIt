local function monitorPlayer(p)
    local function hookCharacter(char)
        char.ChildAdded:Connect(function(item)
            if item:IsA("Tool") and not item.Name:lower():find("rod") then
                task.wait(1) -- Beri waktu server untuk ngeload atribut
                
                local rarity = item:GetAttribute("Rarity") or item:GetAttribute("rarity") or "Common"
                local rarityStr = tostring(rarity):sub(1,1):upper() .. tostring(rarity):sub(2):lower()
                
                if getgenv().FlowConfig.Filters[rarityStr] then
                    local mutation = item:GetAttribute("Mutation") or item:GetAttribute("mutation") or "None"
                    local weight = item:GetAttribute("Weight") or item:GetAttribute("weight") or 0
                    local zone = getPlayerLocation(p)
                    
                    -- LOGIC SPECIAL NOTIFICATION (@here)
                    local pingContent = nil
                    if (item.Name == "Ruby" and mutation == "Gemstone") or rarityStr == "Forgotten" then
                        pingContent = "@here 🚨 **SPECIAL CATCH DETECTED!** 🚨"
                    end

                    sendWebhook({
                        ["content"] = pingContent,
                        ["embeds"] = {{
                            ["title"] = "🎣 Server Catch Log",
                            ["color"] = 0x00B4D8,
                            ["thumbnail"] = {["url"] = "https://www.roblox.com/headshot-thumbnail/image?userId="..p.UserId.."&width=420&height=420&format=png"},
                            ["fields"] = {
                                {["name"] = "🐟 Fish", ["value"] = "```"..item.Name.."```", ["inline"] = true},
                                {["name"] = "✨ Rarity", ["value"] = "```"..rarityStr.."```", ["inline"] = true},
                                {["name"] = "⚖️ Weight", ["value"] = "```"..string.format("%.2f", weight).." kg```", ["inline"] = true},
                                {["name"] = "🧬 Mutation", ["value"] = "```"..tostring(mutation).."```", ["inline"] = true},
                                {["name"] = "📍 Location", ["value"] = "```"..zone.."```", ["inline"] = true},
                                {["name"] = "👤 Player", ["value"] = "```"..p.Name.."```", ["inline"] = true},
                                {["name"] = "🖥️ JobID", ["value"] = "```"..game.JobId.."```", ["inline"] = false}
                            },
                            ["footer"] = {["text"] = "Flow Hub Alpha 1.0.0"}
                        }}
                    })
                end
            end
        end)
    end
    
    if p.Character then hookCharacter(p.Character) end
    p.CharacterAdded:Connect(hookCharacter)
end

-- Hook semua player yang udah ada di server
for _, p in pairs(Players:GetPlayers()) do monitorPlayer(p) end
